{
  "name": "can-see",
  "version": "0.1.0",
  "description": "MCP server that lets Claude Code see and interact with terminal apps",
  "type": "module",
  "main": "dist/server.js",
  "bin": {
    "can-see": "dist/server.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
